								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/inventory?page=1&limit=20",
							"host": ["{{baseUrl}}"],
							"path": ["inventory"],
							"query": [
								{
									"key": "page",
									"value": "1"
