								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Product Name\",\n  \"category\": \"Electronics\",\n  \"quantity\": 100,\n  \"price\": {\n    \"cost\": 50.00,\n    \"selling\": 75.00\n  },\n  \"supplier_id\": \"supplier_id_here\",\n  \"minStockLevel\": 10,\n  \"maxStockLevel\": 500\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/inventory",
							"host": ["{{baseUrl}}"],
							"path": ["inventory"]
						}
					},
					"response": []
				},
				{
					"name": "Update Inventory Item",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Updated Product Name\",\n  \"quantity\": 150\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/{{inventoryId}}",
							"host": ["{{baseUrl}}"],
							"path": ["inventory", "{{inventoryId}}"]
						}
					},
					"response": []
				},
				{
					"name": "Delete Inventory Item",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/inventory/{{inventoryId}}",
							"host": ["{{baseUrl}}"],
							"path": ["inventory", "{{inventoryId}}"]
						}
					},
					"response": []
				}
			]
