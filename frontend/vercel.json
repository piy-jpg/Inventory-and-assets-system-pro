{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://smart-inventory-backend-gold.vercel.app/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://smart-inventory-backend-gold.vercel.app",
    "REACT_APP_SOCKET_URL": "https://smart-inventory-backend-gold.vercel.app"
  },
  "build": {
    "env": {
      "REACT_APP_API_URL": "https://smart-inventory-backend-gold.vercel.app",
      "REACT_APP_SOCKET_URL": "https://smart-inventory-backend-gold.vercel.app"
    }
  }
}
