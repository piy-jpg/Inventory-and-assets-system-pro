{
  "version": 2,
  "name": "smart-inventory-system",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://smart-inventory-backend.vercel.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://smart-inventory-backend.vercel.app"
  },
  "functions": {
    "frontend/api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  }
}
